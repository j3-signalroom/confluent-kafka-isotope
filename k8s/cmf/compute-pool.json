{
  "apiVersion": "cmf.confluent.io/v1",
  "kind": "ComputePool",
  "metadata": {
    "name": "iso-pool"
  },
  "spec": {
    "type": "DEDICATED",
    "clusterSpec": {
      "flinkVersion": "v1_19",
      "image": "confluentinc/cp-flink-sql:1.19-cp8-arm64",
      "flinkConfiguration": {
        "execution.checkpointing.interval": "60 s",
        "state.backend.type": "hashmap"
      },
      "taskManager": {"resource": {"cpu": 0.5, "memory": "1024m"}},
      "jobManager":  {"resource": {"cpu": 0.5, "memory": "1024m"}}
    }
  }
}
